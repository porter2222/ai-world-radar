# AI World Radar local runtime configuration template.
# Copy this file to `.env` in the project root and fill real values locally or on the server.
# Never commit `.env` or paste real API keys / database passwords into docs.

# PostgreSQL used by worker, Alembic and FastAPI Product API.
DATABASE_URL=
# Example format:
# DATABASE_URL=postgresql+psycopg://postgres:<password>@localhost:5432/ai_world_radar

# Runtime agent mode.
# Production/default path is real LLM; use `stub` only for offline fixture tests or explicit fallback drills.
AGENT_MODE=llm

# LLM provider selection.
# Supported values: openai, deepseek, qwen-cn.
LLM_PROVIDER=openai
LLM_MODEL=gpt-5.5
LLM_REQUEST_TIMEOUT_SECONDS=180

# OpenAI / OpenAI-compatible provider.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_USER_AGENT=AI-World-Radar/worker

# Optional GitHub token. Public endpoints can run without it, but rate limits are lower.
GITHUB_TOKEN=

# DeepSeek OpenAI-compatible provider.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Qwen / DashScope OpenAI-compatible provider.
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Optional frontend/API integration config.
AI_WORLD_RADAR_API_BASE_URL=http://127.0.0.1:8016

# Product and pipeline strategy defaults live in typed config.
# Use explicit process env overrides only for local diagnostics.
